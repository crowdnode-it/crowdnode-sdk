{
  "compilerOptions": {
    "target": "ES2020",                                  
    "module": "commonjs",                                
    "declaration": true,                /* REQUIRED: Generates .d.ts files for imports */
    "declarationMap": true,             /* Optional: Helps with "Go to Definition" in VS Code */
    "outDir": "./dist",                 /* REQUIRED: Where the compiled code goes */
    "rootDir": "./src",                 /* REQUIRED: Where your TS files are */
    "strict": true,                                      
    "esModuleInterop": true,                             
    "skipLibCheck": true,                                
    "forceConsistentCasingInFileNames": true 
  },
  "include": ["src/**/*"],              /* Tells TSC to look in your src folder */
  "exclude": ["node_modules", "dist"]
}